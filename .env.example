# ─── NEXUS STORE — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values

# Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Owner Telegram Username (without @)
OWNER_USERNAME=your_username

# Owner Display Name
OWNER_NAME=Your Name

# Database path
DB_PATH=filestore.db

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Referral coins earned per new user
REFERRAL_COINS=1

# Bonus coins new referred users get
NEW_USER_REF_COINS=2

# Force subscribe channels (name:username,name:username)
# For private channels, use invite link hash as username
FORCE_CHANNELS="Channel Name:channel_username"

# Feature flags
ENABLE_LEADERBOARD=true
ENABLE_REFERRALS=true
ENABLE_REDEEM_CODES=true
ENABLE_FORCE_SUBSCRIBE=true
ENABLE_BROADCAST=true
